{
  "name": "slackwire",
  "version": "0.1.0",
  "description": "Command-line tool for sending, updating, and managing Slack messages",
  "license": "MIT",
  "keywords": ["slack", "cli", "slack-cli", "slack-message", "ci", "gitlab", "devops"],
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/slackwire/slackwire.git"
  },
  "homepage": "https://gitlab.com/slackwire/slackwire",
  "bugs": {
    "url": "https://gitlab.com/slackwire/slackwire/-/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "slackwire": "./dist/bundle.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node bundle.mjs",
    "test": "vitest run",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@slackwire/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
