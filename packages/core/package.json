{
  "name": "@slackwire/core",
  "version": "0.1.2",
  "description": "Slack client, template engine, and render pipeline",
  "license": "MIT",
  "author": { "name": "Francois Raubenheimer", "url": "https://gitlab.com/slackwire/slackwire" },
  "keywords": ["slack", "slack-blocks", "template", "mcp", "library"],
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/slackwire/slackwire.git"
  },
  "homepage": "https://gitlab.com/slackwire/slackwire",
  "bugs": {
    "url": "https://gitlab.com/slackwire/slackwire/-/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@slack/web-api": "^7.0.0",
    "ajv": "^8.0.0",
    "https-proxy-agent": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
