{
  "name": "@slackwire/core",
  "version": "0.1.0",
  "description": "Slack client, template engine, and render pipeline",
  "license": "MIT",
  "keywords": ["slack", "slack-blocks", "template", "mcp", "library"],
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/slackwire/slackwire.git"
  },
  "homepage": "https://gitlab.com/slackwire/slackwire",
  "bugs": {
    "url": "https://gitlab.com/slackwire/slackwire/-/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@slack/web-api": "^7.0.0",
    "ajv": "^8.0.0",
    "https-proxy-agent": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
