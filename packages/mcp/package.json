{
  "name": "@slackwire/mcp",
  "version": "0.1.2",
  "description": "MCP server exposing slackwire Slack operations as tools",
  "author": { "name": "Francois Raubenheimer", "url": "https://gitlab.com/slackwire/slackwire" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "slackwire-mcp": "./dist/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": ["slack", "mcp", "model-context-protocol", "cli"],
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/slackwire/slackwire"
  },
  "homepage": "https://gitlab.com/slackwire/slackwire",
  "bugs": {
    "url": "https://gitlab.com/slackwire/slackwire/-/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slackwire/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
